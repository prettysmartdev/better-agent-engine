# Better Agent Engine (BAE) — bae-launcher-webapp base image.
#
# This is a base image for a user's Dockerfile to extend with one or more
# harnesses and a bae-app.toml. The frontend is static content served by the
# SAME baeapi binary used by bae-launcher-api. This image runs ONE process —
# baeapi — and has no entrypoint script or second web server process.
#
# IMPORTANT FOR EXTENDING DOCKERFILES: add harnesses/configuration with COPY
# only. Do NOT override ENTRYPOINT or CMD — doing so prevents baeapi from
# running and defeats both the API and webapp behavior.
#
#   docker build -f Dockerfile.launcher-webapp \
#     -t better-agent-engine:launcher-webapp .

FROM rust:1-bookworm AS rust-build
WORKDIR /build
# launcher-api has a relative path dependency on launcher-core. Keep both
# independently-buildable crates in their own directories in the build context
# so Cargo can resolve that dependency; do not flatten either COPY.
COPY launchers/core/ ./launchers/core/
COPY launchers/api/ ./launchers/api/
RUN cargo build --release --manifest-path launchers/api/Cargo.toml

# Build the frontend separately; only its Vite dist/ output enters the runtime
# image. This follows the same Node/Vite build-stage pattern as Dockerfile.max.
FROM node:22-bookworm AS web-build
WORKDIR /build/web
COPY launchers/webapp/web/package.json launchers/webapp/web/package-lock.json ./
RUN npm ci
COPY launchers/webapp/web/ ./
RUN npm run build

FROM debian:bookworm-slim AS runtime
RUN apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates \
    && rm -rf /var/lib/apt/lists/* \
    && useradd --system --user-group --home-dir /var/lib/bae bae \
    && mkdir -p /etc/bae \
    && chown bae:bae /etc/bae

# This is the identical launcher-api build, with only the webapp's static
# assets added alongside it; no Node runtime is needed in the final image.
COPY --from=rust-build /build/launchers/api/target/release/baeapi /usr/local/bin/baeapi
COPY --from=web-build /build/web/dist/ /usr/local/lib/launchers/webapp/web/dist/

USER bae
ENV BAE_LAUNCHER_API_CONFIG=/etc/bae/bae-app.toml \
    BAE_LAUNCHER_API_ADDR=0.0.0.0:9090 \
    BAE_LAUNCHER_WEBAPP_STATIC_DIR=/usr/local/lib/launchers/webapp/web/dist \
    BAE_LOG=info
# The API/webapp share one plain HTTP port; put this base image behind the
# same TLS-terminating reverse proxy required by the other BAE network ports.
EXPOSE 9090
ENTRYPOINT ["baeapi"]
